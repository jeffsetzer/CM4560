const gameRounds = [
  {q:"A newly-assigned PM has a signed GMP contract but no charter yet. What should happen before any CPM scheduling work begins?",
   opts:["Nothing — the contract already authorizes the schedule","The charter should be drafted and agreed with the sponsor first","The superintendent should set logistics first","The architect should approve the schedule first"], correct:1,
   fb:"The charter establishes agreed success criteria and authority before downstream planning — schedules built without it have no anchor if scope or priorities are later disputed."},
  {q:"Which of these belongs in the project charter rather than the PMP?",
   opts:["Detailed 400-activity CPM schedule","Submittal log numbering convention","PM's authority to approve changes up to $50,000","Risk register with probability and impact ratings"], correct:2,
   fb:"Explicit PM authority thresholds are core charter content — the other three are subsidiary-plan detail that lives in the PMP."},
  {q:"How often should the project charter be updated after it's signed?",
   opts:["Weekly, alongside the schedule","Rarely — it's signed once at initiation","Daily, by the document control coordinator","Every time a change order is issued"], correct:1,
   fb:"The charter is a one-time authorization document. The PMP is the living document that gets updated as the project learns."},
  {q:"A PM is asked to write an aggressive completion date into the charter that they privately believe is unrealistic. Per PMI's Code of Ethics, what should they do first?",
   opts:["Write the date requested without comment","State their concern and the basis for it, in writing, before finalizing the charter","Refuse to draft the charter at all","Quietly plan to miss the date without saying anything now"], correct:1,
   fb:"PMI's Honesty value calls for communicating the truth as the PM understands it — documenting the concern gives the sponsor an informed choice rather than silent compliance or silent refusal."},
  {q:"Which subsidiary plan is primarily responsible for protecting a milestone date stated in the charter?",
   opts:["Procurement Management Plan","Schedule Management Plan","Quality Management Plan","Communications Management Plan"], correct:1,
   fb:"The Schedule Management Plan governs the CPM schedule, update frequency, and float policy used to protect charter milestone commitments."},
  {q:"Why should document control systems (submittal log, RFI log, change order log) be set up BEFORE mobilization rather than after?",
   opts:["It's required by OSHA","Retrofitting a numbering convention onto untracked early records is effectively impossible","The architect requires it before issuing drawings","It has no real effect on the project"], correct:1,
   fb:"Once early decisions and correspondence happen without a tracking system, that decision history generally can't be reconstructed later — exactly when disputes need it most."},
  {q:"What is the main difference in AUDIENCE between the charter and the PMP?",
   opts:["The charter is for the sponsor/executives/PM; the PMP is for the full project team","Both are written only for the PM","The charter is for subcontractors only","The PMP is only read by the owner's attorney"], correct:0,
   fb:"The charter's short, executive-level content serves sponsors and leadership; the PMP's operational detail is what the full team actually works from day to day."},
  {q:"A kickoff meeting agenda should generally move from which sequence to which?",
   opts:["Operational logistics first, then alignment on goals","Alignment on charter/roles first, then operational logistics","Safety orientation first, then everything else","There's no meaningful order to a kickoff agenda"], correct:1,
   fb:"Starting with alignment (roles, charter, success criteria) before operational detail (logistics, submittals) ensures the team is solving the right problems, in the right order."},
  {q:"The charter states the GMP is $28.5M. Where does the DETAILED cost-tracking structure (cost codes, forecasting method) actually live?",
   opts:["In the charter itself, as an appendix","In the Cost Management Plan, part of the PMP","Nowhere — it's tracked informally","In the safety plan"], correct:1,
   fb:"The Cost Management Plan (a PMP subsidiary plan) defines cost codes, tracking, and forecasting methodology — the charter only states the top-line budget figure."},
  {q:"A selection committee member has a personal friendship with a bidding firm's principal during project setup vendor selection. What does PMI's Fairness value call for?",
   opts:["Nothing, since no money changed hands","Proactive disclosure to the committee before evaluation begins","Waiting to see if anyone asks about it later","Scoring the firm slightly lower to compensate"], correct:1,
   fb:"PMI's ethical standard calls for proactive disclosure regardless of whether the person believes they can remain objective — the appearance of a conflict alone damages trust in the process."}
];
let gIdx = 0, gScore = 0, gAnswered = false;

function gRender(){
  const r = gameRounds[gIdx];
  document.getElementById('game-progress-fill').style.width = ((gIdx)/gameRounds.length*100)+'%';
  document.getElementById('game-round-label').textContent = 'Round ' + (gIdx+1) + ' of ' + gameRounds.length;
  document.getElementById('game-scenario').textContent = r.q;
  const optsDiv = document.getElementById('game-opts');
  optsDiv.innerHTML = '';
  gAnswered = false;
  r.opts.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'game-opt';
    btn.textContent = opt;
    btn.onclick = () => gAnswer(i);
    optsDiv.appendChild(btn);
  });
  const fb = document.getElementById('game-feedback');
  fb.className = 'game-feedback';
  fb.textContent = '';
  document.getElementById('game-next-btn').classList.remove('show');
}

function gAnswer(i){
  if(gAnswered) return;
  gAnswered = true;
  const r = gameRounds[gIdx];
  const opts = document.querySelectorAll('.game-opt');
  opts.forEach((btn, idx) => {
    btn.classList.add('locked');
    if(idx === r.correct) btn.classList.add('correct');
    else if(idx === i) btn.classList.add('wrong');
  });
  const fb = document.getElementById('game-feedback');
  if(i === r.correct){
    gScore += 10;
    fb.className = 'game-feedback show gf-correct';
    fb.innerHTML = '<strong>Correct (+10 pts).</strong> ' + r.fb;
  } else {
    fb.className = 'game-feedback show gf-wrong';
    fb.innerHTML = '<strong>Not quite.</strong> ' + r.fb;
  }
  document.getElementById('game-score').textContent = 'Score: ' + gScore;
  const nextBtn = document.getElementById('game-next-btn');
  nextBtn.classList.add('show');
  nextBtn.textContent = (gIdx === gameRounds.length - 1) ? 'See Final Results' : 'Next Round →';
}

function gNext(){
  gIdx++;
  if(gIdx >= gameRounds.length){
    gFinal();
  } else {
    gRender();
  }
}

function gFinal(){
  document.getElementById('game-progress-fill').style.width = '100%';
  const body = document.getElementById('game-active-body');
  const max = gameRounds.length * 10;
  const pct = Math.round((gScore/max)*100);
  let tier = 'Keep Studying';
  if(pct >= 90) tier = 'Chartering Expert';
  else if(pct >= 75) tier = 'Solid PM Judgment';
  else if(pct >= 60) tier = 'Getting There';
  body.innerHTML = '<div class="game-final">' +
    '<div class="score-big">' + gScore + ' / ' + max + '</div>' +
    '<div class="tier">' + tier + ' — ' + pct + '%</div>' +
    '<button class="game-restart" onclick="gStart()">Play Again</button>' +
    '</div>';
}

function gStart(){
  gIdx = 0; gScore = 0;
  document.getElementById('game-score').textContent = 'Score: 0';
  const body = document.getElementById('game-active-body');
  body.innerHTML = '<div class="game-progress"><div class="game-progress-fill" id="game-progress-fill" style="width:0%"></div></div>' +
    '<div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px;" id="game-round-label"></div>' +
    '<div class="game-scenario" id="game-scenario"></div>' +
    '<div class="game-opts" id="game-opts"></div>' +
    '<div class="game-feedback" id="game-feedback"></div>' +
    '<button class="game-next" id="game-next-btn" onclick="gNext()">Next Round →</button>';
  gRender();
}
document.addEventListener('DOMContentLoaded', gStart);

</script>
